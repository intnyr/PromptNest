<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="PromptNest.App.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:PromptNest.App.ViewModels"
    Title="PromptNest"
    mc:Ignorable="d">
    <Grid
        x:Name="ShellRoot"
        MinWidth="{StaticResource PromptNestWindowMinWidth}"
        MinHeight="{StaticResource PromptNestWindowMinHeight}"
        Background="{StaticResource PromptNestWindowBackgroundBrush}"
        KeyDown="OnShellRootKeyDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="38" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="AppTitleBar"
            Grid.Row="0"
            Padding="14,0,10,0"
            Background="{StaticResource PromptNestAppChromeBrush}"
            BorderBrush="{StaticResource PromptNestBorderMutedBrush}"
            BorderThickness="0,0,0,1"
            ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border
                Width="22"
                Height="22"
                VerticalAlignment="Center"
                Background="{StaticResource PromptNestAccentSubtleBrush}"
                BorderBrush="{StaticResource PromptNestAccentBrush}"
                BorderThickness="1"
                CornerRadius="6">
                <FontIcon
                    FontSize="13"
                    Foreground="{StaticResource PromptNestAccentBrush}"
                    Glyph="&#xE8D7;" />
            </Border>

            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                FontFamily="{StaticResource PromptNestFontFamilyDisplay}"
                FontSize="{StaticResource PromptNestFontSizeBodyLarge}"
                FontWeight="SemiBold"
                Foreground="{StaticResource PromptNestTextPrimaryBrush}"
                Text="PromptNest" />

            <!-- Drag region only; system caption controls are rendered by the host. -->
            <Grid
                Grid.Column="2"
                Width="138"
                AutomationProperties.AccessibilityView="Raw"
                IsHitTestVisible="False" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48" />
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="420" />
                <ColumnDefinition x:Name="EditorColumn" Width="*" MinWidth="420" />
            </Grid.ColumnDefinitions>

            <ContentControl
                x:Name="NavigationRailHost"
                Grid.Column="0"
                Background="{StaticResource PromptNestNavigationRailBrush}"
                IsTabStop="False" />

            <ContentControl
                x:Name="SidebarHost"
                Grid.Column="1"
                Background="{StaticResource PromptNestSidebarBrush}"
                BorderBrush="{StaticResource PromptNestBorderMutedBrush}"
                BorderThickness="0,0,1,0"
                IsTabStop="False" />

            <ContentControl
                x:Name="LibraryHost"
                Grid.Column="2"
                Background="{StaticResource PromptNestPaneBrush}"
                BorderBrush="{StaticResource PromptNestBorderMutedBrush}"
                BorderThickness="0,0,1,0"
                IsTabStop="False" />

            <ContentControl
                x:Name="EditorHost"
                Grid.Column="3"
                Background="{StaticResource PromptNestEditorBrush}"
                IsTabStop="False" />

            <Grid
                Grid.Column="0"
                HorizontalAlignment="Center"
                Margin="0,12,0,12"
                RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Button
                    Grid.Row="0"
                    Width="{StaticResource PromptNestRailButtonSize}"
                    Height="{StaticResource PromptNestRailButtonSize}"
                    AutomationProperties.Name="Prompt library"
                    Background="{StaticResource PromptNestSelectedRowBrush}"
                    BorderBrush="Transparent"
                    CornerRadius="{StaticResource PromptNestControlRadius}"
                    ToolTipService.ToolTip="Prompt library">
                    <FontIcon
                        Foreground="{StaticResource PromptNestAccentBrush}"
                        Glyph="&#xE8A5;" />
                </Button>
                <Button
                    Grid.Row="1"
                    Width="{StaticResource PromptNestRailButtonSize}"
                    Height="{StaticResource PromptNestRailButtonSize}"
                    AutomationProperties.Name="Tags"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    CornerRadius="{StaticResource PromptNestControlRadius}"
                    ToolTipService.ToolTip="Tags">
                    <FontIcon
                        Foreground="{StaticResource PromptNestIconMutedBrush}"
                        Glyph="&#xE8EC;" />
                </Button>
                <Button
                    Grid.Row="2"
                    Width="{StaticResource PromptNestRailButtonSize}"
                    Height="{StaticResource PromptNestRailButtonSize}"
                    AutomationProperties.Name="Run prompt"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    CornerRadius="{StaticResource PromptNestControlRadius}"
                    ToolTipService.ToolTip="Run prompt">
                    <FontIcon
                        Foreground="{StaticResource PromptNestIconMutedBrush}"
                        Glyph="&#xE8B7;" />
                </Button>
                <Button
                    Grid.Row="4"
                    Width="{StaticResource PromptNestRailButtonSize}"
                    Height="{StaticResource PromptNestRailButtonSize}"
                    AutomationProperties.Name="Settings"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Click="OnSettingsClick"
                    CornerRadius="{StaticResource PromptNestControlRadius}"
                    ToolTipService.ToolTip="Settings (Ctrl+,)">
                    <FontIcon
                        Foreground="{StaticResource PromptNestIconMutedBrush}"
                        Glyph="&#xE713;" />
                </Button>
                <Button
                    Grid.Row="5"
                    Width="{StaticResource PromptNestRailButtonSize}"
                    Height="{StaticResource PromptNestRailButtonSize}"
                    AutomationProperties.Name="Help"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    CornerRadius="{StaticResource PromptNestControlRadius}"
                    ToolTipService.ToolTip="Help">
                    <FontIcon
                        Foreground="{StaticResource PromptNestIconMutedBrush}"
                        Glyph="&#xE897;" />
                </Button>
                <Button
                    Grid.Row="6"
                    Width="{StaticResource PromptNestRailButtonSize}"
                    Height="{StaticResource PromptNestRailButtonSize}"
                    AutomationProperties.Name="Profile"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    CornerRadius="{StaticResource PromptNestControlRadius}"
                    ToolTipService.ToolTip="Profile">
                    <FontIcon
                        Foreground="{StaticResource PromptNestIconMutedBrush}"
                        Glyph="&#xE77B;" />
                </Button>
            </Grid>

            <Grid
                Grid.Column="1"
                Padding="{StaticResource PromptNestPanePadding}"
                RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ListView
                    Grid.Row="0"
                    MaxHeight="172"
                    Background="Transparent"
                    BorderThickness="0"
                    ItemsSource="{x:Bind ViewModel.Library.NavigationItems, Mode=OneWay}"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Button
                                Height="{StaticResource PromptNestFolderRowHeight}"
                                Padding="{StaticResource PromptNestFolderRowPadding}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Background="{Binding IsSelected, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=SelectedRow}"
                                BorderBrush="Transparent"
                                Click="OnNavigationClick"
                                CornerRadius="{StaticResource PromptNestControlRadius}"
                                Tag="{Binding Id}">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Foreground="{StaticResource PromptNestTextPrimaryBrush}"
                                        Text="{Binding Label}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Foreground="{StaticResource PromptNestTextTertiaryBrush}"
                                        Text="{Binding CountText}" />
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Grid Grid.Row="1" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{StaticResource PromptNestSectionHeaderStyle}"
                        Text="FOLDERS" />
                    <Button
                        Grid.Column="1"
                        Width="{StaticResource PromptNestSmallIconButtonSize}"
                        Height="{StaticResource PromptNestSmallIconButtonSize}"
                        AutomationProperties.Name="Add folder"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        ToolTipService.ToolTip="Add folder">
                        <FontIcon
                            FontSize="{StaticResource PromptNestIconGlyphSmall}"
                            Foreground="{StaticResource PromptNestIconMutedBrush}"
                            Glyph="&#xE710;" />
                    </Button>
                </Grid>

                <ListView
                    Grid.Row="2"
                    Background="Transparent"
                    BorderThickness="0"
                    ItemsSource="{x:Bind ViewModel.Library.VisibleFolders, Mode=OneWay}"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid
                                Height="{StaticResource PromptNestFolderRowHeight}"
                                Padding="{Binding IndentPixels, Converter={StaticResource DepthToPaddingConverter}}"
                                ColumnSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button
                                    Width="{StaticResource PromptNestFolderToggleSize}"
                                    Height="{StaticResource PromptNestFolderToggleSize}"
                                    Padding="0"
                                    AutomationProperties.Name="Toggle folder"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    Click="OnFolderToggleClick"
                                    IsEnabled="{Binding HasChildren}"
                                    Tag="{Binding Id}">
                                    <FontIcon
                                        FontSize="{StaticResource PromptNestIconGlyphSmall}"
                                        Foreground="{StaticResource PromptNestIconMutedBrush}"
                                        Glyph="{Binding IsExpanded, Converter={StaticResource FolderChevronGlyphConverter}}" />
                                </Button>
                                <Button
                                    Grid.Column="1"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Background="{Binding IsSelected, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=SelectedRow}"
                                    BorderBrush="Transparent"
                                    Click="OnFolderClick"
                                    CornerRadius="{StaticResource PromptNestControlRadius}"
                                    Tag="{Binding Id}">
                                    <TextBlock
                                        Foreground="{StaticResource PromptNestTextSecondaryBrush}"
                                        Text="{Binding Name}" />
                                </Button>
                                <TextBlock
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource PromptNestTextTertiaryBrush}"
                                    Text="{Binding CountText}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBlock
                    Grid.Row="3"
                    Margin="0,10,0,0"
                    Style="{StaticResource PromptNestSectionHeaderStyle}"
                    Text="COLLECTIONS" />

                <ListView
                    Grid.Row="4"
                    Background="Transparent"
                    BorderThickness="0"
                    ItemsSource="{x:Bind ViewModel.Library.Collections, Mode=OneWay}"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Button
                                Height="{StaticResource PromptNestFolderRowHeight}"
                                Padding="{StaticResource PromptNestFolderRowPadding}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Background="{Binding IsSelected, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=SelectedRow}"
                                BorderBrush="Transparent"
                                Click="OnCollectionClick"
                                CornerRadius="{StaticResource PromptNestControlRadius}"
                                Tag="{Binding Id}">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Foreground="{StaticResource PromptNestTextSecondaryBrush}"
                                        Text="{Binding Label}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Foreground="{StaticResource PromptNestTextTertiaryBrush}"
                                        Text="{Binding CountText}" />
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <Grid
                Grid.Column="2"
                Padding="{StaticResource PromptNestToolbarPadding}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="54" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <TextBox
                        x:Name="SearchBox"
                        Padding="42,0,86,0"
                        AutomationProperties.AutomationId="PromptNest.SearchBox"
                        KeyDown="OnSearchBoxKeyDown"
                        PlaceholderText="Search prompts"
                        Style="{StaticResource PromptNestSearchBoxStyle}"
                        TextChanged="OnSearchTextChanged" />
                    <FontIcon
                        Margin="14,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        AutomationProperties.AccessibilityView="Raw"
                        FontSize="{StaticResource PromptNestIconGlyphMedium}"
                        Foreground="{StaticResource PromptNestIconMutedBrush}"
                        Glyph="&#xE721;"
                        IsHitTestVisible="False" />
                    <StackPanel
                        Margin="0,0,10,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="6">
                        <Button
                            MinWidth="54"
                            Height="24"
                            AutomationProperties.Name="Focus search"
                            AutomationProperties.HelpText="Keyboard shortcut: Control plus K"
                            Background="{StaticResource PromptNestPaneElevatedBrush}"
                            BorderBrush="{StaticResource PromptNestBorderMutedBrush}"
                            Click="OnFocusSearchClick"
                            Content="Ctrl+K"
                            FontSize="{StaticResource PromptNestFontSizeCaption}"
                            Foreground="{StaticResource PromptNestTextSecondaryBrush}"
                            Padding="6,0"
                            ToolTipService.ToolTip="Focus search (Ctrl+K)" />
                        <Button
                            Width="{StaticResource PromptNestMinTouchTarget}"
                            Height="{StaticResource PromptNestMinTouchTarget}"
                            AutomationProperties.Name="Clear search"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Click="OnClearSearchClick"
                            Padding="0"
                            ToolTipService.ToolTip="Clear search (Esc)">
                            <FontIcon
                                FontSize="{StaticResource PromptNestIconGlyphSmall}"
                                Foreground="{StaticResource PromptNestIconDefaultBrush}"
                                Glyph="&#xE711;" />
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid
                    Grid.Row="1"
                    Margin="0,6,0,8"
                    ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            AccessKey="N"
                            AutomationProperties.AutomationId="PromptNest.NewPromptButton"
                            AutomationProperties.Name="New prompt"
                            Click="OnNewPromptClick"
                            Content="New"
                            MinWidth="72"
                            Height="{StaticResource PromptNestIconButtonSize}"
                            Background="{StaticResource PromptNestAccentBrush}"
                            BorderBrush="Transparent"
                            CornerRadius="{StaticResource PromptNestControlRadius}"
                            Foreground="{StaticResource PromptNestIconSelectedBrush}"
                            ToolTipService.ToolTip="New prompt (Ctrl+N)" />
                        <Button
                            AccessKey="D"
                            AutomationProperties.AutomationId="PromptNest.DuplicatePromptButton"
                            AutomationProperties.Name="Duplicate selected prompt"
                            Click="OnDuplicateClick"
                            Content="Duplicate"
                            Height="{StaticResource PromptNestIconButtonSize}"
                            Padding="10,0"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            CornerRadius="{StaticResource PromptNestControlRadius}"
                            Foreground="{StaticResource PromptNestTextPrimaryBrush}"
                            ToolTipService.ToolTip="Duplicate (Ctrl+D)" />
                        <Button
                            AutomationProperties.Name="New folder"
                            Click="OnNewFolderClick"
                            Content="Folder"
                            Height="{StaticResource PromptNestIconButtonSize}"
                            Padding="10,0"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            CornerRadius="{StaticResource PromptNestControlRadius}"
                            Foreground="{StaticResource PromptNestTextPrimaryBrush}"
                            ToolTipService.ToolTip="New folder" />
                        <Button
                            AutomationProperties.Name="Manage tags"
                            Click="OnManageTagsClick"
                            Content="Tags"
                            Height="{StaticResource PromptNestIconButtonSize}"
                            Padding="10,0"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            CornerRadius="{StaticResource PromptNestControlRadius}"
                            Foreground="{StaticResource PromptNestTextPrimaryBrush}"
                            ToolTipService.ToolTip="Manage tags" />
                        <Button
                            Width="{StaticResource PromptNestIconButtonSize}"
                            Height="{StaticResource PromptNestIconButtonSize}"
                            AutomationProperties.Name="Filter prompts"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Click="OnFilterClick"
                            CornerRadius="{StaticResource PromptNestControlRadius}"
                            ToolTipService.ToolTip="Filters">
                            <FontIcon
                                FontSize="{StaticResource PromptNestIconGlyphMedium}"
                                Foreground="{StaticResource PromptNestIconDefaultBrush}"
                                Glyph="&#xE71C;" />
                        </Button>
                        <Button
                            Width="{StaticResource PromptNestIconButtonSize}"
                            Height="{StaticResource PromptNestIconButtonSize}"
                            AutomationProperties.Name="More library actions"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Click="OnOverflowClick"
                            CornerRadius="{StaticResource PromptNestControlRadius}"
                            ToolTipService.ToolTip="More actions">
                            <FontIcon
                                FontSize="{StaticResource PromptNestIconGlyphMedium}"
                                Foreground="{StaticResource PromptNestIconDefaultBrush}"
                                Glyph="&#xE712;" />
                        </Button>
                    </StackPanel>

                    <Button
                        x:Name="SortButton"
                        Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Padding="8,0"
                        AutomationProperties.Name="Sort order"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="OnSortClick"
                        Content="Sort: Relevance"
                        Foreground="{StaticResource PromptNestTextSecondaryBrush}"
                        ToolTipService.ToolTip="Cycle sort order" />
                </Grid>

                <Grid
                    Grid.Row="2"
                    Margin="0,0,0,6">
                    <TextBlock
                        AutomationProperties.LiveSetting="Polite"
                        FontSize="{StaticResource PromptNestFontSizeBodySmall}"
                        Foreground="{StaticResource PromptNestTextSecondaryBrush}"
                        Text="{Binding Library.Pagination.ResultCountText}" />
                </Grid>

                <ListView
                    Grid.Row="3"
                    AutomationProperties.AutomationId="PromptNest.PromptList"
                    Background="Transparent"
                    BorderThickness="0"
                    IsItemClickEnabled="True"
                    ItemClick="OnPromptItemClick"
                    ItemsSource="{Binding Library.PromptList}"
                    SelectionMode="None">
                    <ListView.ItemContainerStyle>
                        <Style BasedOn="{StaticResource PromptNestPromptListRowStyle}" TargetType="ListViewItem" />
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Padding="8"
                                Background="{Binding IsSelected, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=SelectedRow}"
                                BorderBrush="{StaticResource PromptNestBorderMutedBrush}"
                                BorderThickness="0,0,0,1">
                                <Grid RowSpacing="7">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource PromptNestTextPrimaryBrush}"
                                            Text="{Binding Title}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Foreground="{StaticResource PromptNestTextTertiaryBrush}"
                                            Text="{Binding DateText}" />
                                        <Button
                                            Grid.Column="2"
                                            Width="{StaticResource PromptNestSmallIconButtonSize}"
                                            Height="{StaticResource PromptNestSmallIconButtonSize}"
                                            AutomationProperties.Name="{Binding FavoriteAccessibleName}"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            Click="OnFavoriteClick"
                                            CornerRadius="{StaticResource PromptNestControlRadius}"
                                            Padding="0"
                                            Tag="{Binding Id}"
                                            ToolTipService.ToolTip="{Binding FavoriteAccessibleName}">
                                            <FontIcon
                                                FontSize="{StaticResource PromptNestIconGlyphLarge}"
                                                Foreground="{StaticResource PromptNestWarningBrush}"
                                                Glyph="{Binding FavoriteGlyph}" />
                                        </Button>
                                    </Grid>
                                    <TextBlock
                                        Grid.Row="1"
                                        Foreground="{StaticResource PromptNestTextSecondaryBrush}"
                                        MaxLines="2"
                                        Text="{Binding Preview}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="Wrap" />
                                    <ItemsControl
                                        Grid.Row="2"
                                        ItemsSource="{Binding Tags}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="6" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource PromptNestTagChipStyle}">
                                                    <TextBlock
                                                        Foreground="{StaticResource PromptNestTextSecondaryBrush}"
                                                        Text="{Binding Name}" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Border
                    Grid.Row="3"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding Library.IsPromptListStateVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock
                        Foreground="{StaticResource PromptNestTextSecondaryBrush}"
                        Text="{Binding Library.PromptListStateMessage}" />
                </Border>

                <Grid
                    Grid.Row="4"
                    Padding="0,8,0,0">
                    <StackPanel
                        HorizontalAlignment="Left"
                        Orientation="Horizontal"
                        Spacing="6">
                        <Button
                            Width="{StaticResource PromptNestPaginationButtonSize}"
                            Height="{StaticResource PromptNestPaginationButtonSize}"
                            AutomationProperties.Name="Previous page"
                            Click="OnPreviousPageClick"
                            Content="‹"
                            CornerRadius="{StaticResource PromptNestControlRadius}"
                            Padding="0"
                            ToolTipService.ToolTip="Previous page" />
                        <Button
                            Width="{StaticResource PromptNestPaginationButtonSize}"
                            Height="{StaticResource PromptNestPaginationButtonSize}"
                            AutomationProperties.Name="Current page"
                            Background="{StaticResource PromptNestAccentBrush}"
                            BorderBrush="Transparent"
                            Content="{Binding Library.Pagination.PageNumber}"
                            CornerRadius="{StaticResource PromptNestControlRadius}"
                            Foreground="{StaticResource PromptNestIconSelectedBrush}"
                            IsHitTestVisible="False"
                            Padding="0" />
                        <Button
                            Width="{StaticResource PromptNestPaginationButtonSize}"
                            Height="{StaticResource PromptNestPaginationButtonSize}"
                            AutomationProperties.Name="Next page"
                            Click="OnNextPageClick"
                            Content="›"
                            CornerRadius="{StaticResource PromptNestControlRadius}"
                            Padding="0"
                            ToolTipService.ToolTip="Next page" />
                    </StackPanel>
                    <TextBlock
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        AutomationProperties.LiveSetting="Polite"
                        FontSize="{StaticResource PromptNestFontSizeBodySmall}"
                        Foreground="{StaticResource PromptNestTextSecondaryBrush}"
                        Text="{Binding Library.Pagination.RangeText}" />
                </Grid>
                </Grid>

            <Border
                x:Name="SettingsPane"
                Grid.Column="3"
                MinWidth="420"
                MaxWidth="560"
                HorizontalAlignment="Right"
                AutomationProperties.Name="Settings panel"
                Background="{StaticResource PromptNestEditorBrush}"
                BorderBrush="{StaticResource PromptNestBorderMutedBrush}"
                BorderThickness="1,0,0,0"
                Padding="18"
                Visibility="Collapsed">
                <Grid RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <TextBlock
                            AutomationProperties.HeadingLevel="Level1"
                            FontSize="{StaticResource PromptNestFontSizeTitle}"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource PromptNestTextPrimaryBrush}"
                            Text="Settings" />
                        <Button
                            Width="{StaticResource PromptNestIconButtonSize}"
                            Height="{StaticResource PromptNestIconButtonSize}"
                            HorizontalAlignment="Right"
                            AutomationProperties.Name="Close settings"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Click="OnCloseSettingsClick"
                            CornerRadius="{StaticResource PromptNestControlRadius}"
                            Padding="0"
                            ToolTipService.ToolTip="Close settings (Esc)">
                            <FontIcon
                                FontSize="{StaticResource PromptNestIconGlyphSmall}"
                                Foreground="{StaticResource PromptNestIconDefaultBrush}"
                                Glyph="&#xE711;" />
                        </Button>
                    </Grid>
                    <ScrollViewer Grid.Row="1">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="8">
                                <TextBlock AutomationProperties.HeadingLevel="Level2" Style="{StaticResource PromptNestFieldLabelStyle}" Text="Appearance" />
                                <ComboBox SelectedIndex="0">
                                    <ComboBoxItem Content="System dark" />
                                    <ComboBoxItem Content="Dark" />
                                    <ComboBoxItem Content="High contrast aware" />
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Spacing="8">
                                <TextBlock AutomationProperties.HeadingLevel="Level2" Style="{StaticResource PromptNestFieldLabelStyle}" Text="Global hotkey" />
                                <TextBox
                                    IsReadOnly="True"
                                    Style="{StaticResource PromptNestSearchBoxStyle}"
                                    Text="Win+Shift+Space" />
                            </StackPanel>
                            <StackPanel Spacing="8">
                                <TextBlock AutomationProperties.HeadingLevel="Level2" Style="{StaticResource PromptNestFieldLabelStyle}" Text="Data management" />
                                <StackPanel Orientation="Horizontal">
                                    <Button
                                        Click="OnImportPromptsClick"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="Import prompts"
                                        Content="Import"
                                        ToolTipService.ToolTip="Import a PromptNest JSON file." />
                                    <Button
                                        Click="OnExportPromptsClick"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="Export prompts"
                                        Content="Export"
                                        ToolTipService.ToolTip="Export the current PromptNest library to JSON." />
                                    <Button
                                        Click="OnCreateBackupClick"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="Create backup"
                                        Content="Create backup"
                                        ToolTipService.ToolTip="Create a local backup before major imports." />
                                </StackPanel>
                                <TextBlock
                                    Foreground="{StaticResource PromptNestTextSecondaryBrush}"
                                    Text="{Binding DataManagementStatusText}"
                                    TextWrapping="Wrap" />
                                <CheckBox Content="Keep last 7 backups" IsChecked="True" />
                            </StackPanel>
                            <StackPanel Spacing="8">
                                <TextBlock AutomationProperties.HeadingLevel="Level2" Style="{StaticResource PromptNestFieldLabelStyle}" Text="Updates" />
                                <ComboBox IsEnabled="False" SelectedIndex="0">
                                    <ComboBoxItem Content="Stable" />
                                    <ComboBoxItem Content="Beta" />
                                    <ComboBoxItem Content="Dev" />
                                </ComboBox>
                                <ToggleSwitch
                                    Header="Automatic update checks"
                                    IsEnabled="False"
                                    IsOn="{Binding UpdateChecksEnabled, Mode=OneWay}" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Click="OnCheckForUpdatesClick" Content="Check now" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource PromptNestTextSecondaryBrush}"
                                        Text="{Binding UpdateChannelText}" />
                                </StackPanel>
                                <TextBlock
                                    Foreground="{StaticResource PromptNestTextTertiaryBrush}"
                                    Text="{Binding UpdateStatusText}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Spacing="8">
                                <TextBlock AutomationProperties.HeadingLevel="Level2" Style="{StaticResource PromptNestFieldLabelStyle}" Text="Tray menu" />
                                <ItemsControl x:Name="TrayCommandList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock
                                                Margin="0,2"
                                                Foreground="{StaticResource PromptNestTextSecondaryBrush}"
                                                Text="{Binding}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <TextBlock
                                Foreground="{StaticResource PromptNestTextTertiaryBrush}"
                                Text="PromptNest v1.0 local-first preview" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Grid
                x:Name="EditorPane"
                Grid.Column="3"
                Padding="{StaticResource PromptNestPanePadding}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="36" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="56" />
                </Grid.RowDefinitions>

                <Grid
                    Grid.Row="0"
                    BorderBrush="{StaticResource PromptNestBorderMutedBrush}"
                    BorderThickness="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Grid>
                            <Button
                                AutomationProperties.Name="Edit tab, selected"
                                Content="Edit"
                                Foreground="{StaticResource PromptNestTextPrimaryBrush}"
                                Style="{StaticResource PromptNestCommandTabStyle}" />
                            <Border
                                Height="2"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Bottom"
                                AutomationProperties.AccessibilityView="Raw"
                                Background="{StaticResource PromptNestAccentBrush}" />
                        </Grid>
                        <Button
                            AutomationProperties.Name="Preview tab"
                            Content="Preview"
                            Style="{StaticResource PromptNestCommandTabStyle}" />
                        <Button
                            AutomationProperties.Name="Variables tab"
                            Content="Variables"
                            Style="{StaticResource PromptNestCommandTabStyle}" />
                        <Button
                            AutomationProperties.Name="History tab"
                            Content="History"
                            Style="{StaticResource PromptNestCommandTabStyle}" />
                        <Button
                            Width="{StaticResource PromptNestIconButtonSize}"
                            Height="{StaticResource PromptNestIconButtonSize}"
                            AutomationProperties.Name="More editor actions"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            ToolTipService.ToolTip="More editor actions">
                            <FontIcon
                                FontSize="{StaticResource PromptNestIconGlyphMedium}"
                                Foreground="{StaticResource PromptNestIconDefaultBrush}"
                                Glyph="&#xE712;" />
                        </Button>
                    </StackPanel>
                    <Button
                        Grid.Column="1"
                        Width="{StaticResource PromptNestIconButtonSize}"
                        Height="{StaticResource PromptNestIconButtonSize}"
                        AutomationProperties.Name="Expand editor"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        ToolTipService.ToolTip="Expand editor">
                        <FontIcon
                            FontSize="{StaticResource PromptNestIconGlyphMedium}"
                            Foreground="{StaticResource PromptNestIconDefaultBrush}"
                            Glyph="&#xE740;" />
                    </Button>
                </Grid>

                <StackPanel
                    Grid.Row="1"
                    Margin="0,14,0,12"
                    Spacing="10">
                    <TextBlock
                        x:Name="TitleLabel"
                        Style="{StaticResource PromptNestFieldLabelStyle}"
                        Text="Title" />
                    <TextBox
                        x:Name="TitleBox"
                        AutomationProperties.AutomationId="PromptNest.TitleBox"
                        AutomationProperties.LabeledBy="{Binding ElementName=TitleLabel}"
                        AutomationProperties.Name="Prompt title"
                        PlaceholderText="Untitled prompt"
                        TextChanged="OnTitleTextChanged"
                        Text="{Binding Library.SelectedPrompt.Title, Mode=OneWay}"
                        Style="{StaticResource PromptNestSearchBoxStyle}" />
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="8">
                            <TextBlock
                                x:Name="FolderLabel"
                                Style="{StaticResource PromptNestFieldLabelStyle}"
                                Text="Folder" />
                            <Button
                                Height="34"
                                HorizontalContentAlignment="Stretch"
                                AutomationProperties.LabeledBy="{Binding ElementName=FolderLabel}"
                                AutomationProperties.Name="Select folder"
                                Background="{StaticResource PromptNestEditorBrush}"
                                BorderBrush="{StaticResource PromptNestBorderMutedBrush}"
                                CornerRadius="{StaticResource PromptNestControlRadius}"
                                ToolTipService.ToolTip="Choose a folder for this prompt">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon
                                        FontSize="14"
                                        Foreground="{StaticResource PromptNestIconMutedBrush}"
                                        Glyph="&#xE8B7;" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Foreground="{StaticResource PromptNestTextPrimaryBrush}"
                                        Text="{Binding Library.SelectedPrompt.FolderPath}"
                                        TextTrimming="CharacterEllipsis" />
                                    <FontIcon
                                        Grid.Column="2"
                                        FontSize="12"
                                        Foreground="{StaticResource PromptNestIconMutedBrush}"
                                        Glyph="&#xE70D;" />
                                </Grid>
                            </Button>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="8">
                            <TextBlock
                                x:Name="TagsLabel"
                                Style="{StaticResource PromptNestFieldLabelStyle}"
                                Text="Tags" />
                            <Border
                                MinHeight="34"
                                Padding="8,5"
                                Background="{StaticResource PromptNestEditorBrush}"
                                BorderBrush="{StaticResource PromptNestBorderMutedBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource PromptNestControlRadius}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <ItemsControl ItemsSource="{Binding Library.SelectedPrompt.Tags}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="6" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource PromptNestTagChipStyle}">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock
                                                            Foreground="{StaticResource PromptNestTextSecondaryBrush}"
                                                            Text="{Binding Name}" />
                                                        <Button
                                                            Width="{StaticResource PromptNestChipRemoveSize}"
                                                            Height="{StaticResource PromptNestChipRemoveSize}"
                                                            AutomationProperties.Name="{Binding RemoveAccessibleName}"
                                                            Background="Transparent"
                                                            BorderBrush="Transparent"
                                                            Click="OnRemoveTagClick"
                                                            CornerRadius="{StaticResource PromptNestControlRadius}"
                                                            Padding="0"
                                                            Tag="{Binding Name}"
                                                            ToolTipService.ToolTip="{Binding RemoveAccessibleName}">
                                                            <FontIcon
                                                                FontSize="{StaticResource PromptNestIconGlyphSmall}"
                                                                Foreground="{StaticResource PromptNestIconDefaultBrush}"
                                                                Glyph="&#xE711;" />
                                                        </Button>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBox
                                        x:Name="TagInput"
                                        MinWidth="96"
                                        Height="24"
                                        VerticalAlignment="Center"
                                        AutomationProperties.AutomationId="PromptNest.TagInput"
                                        AutomationProperties.LabeledBy="{Binding ElementName=TagsLabel}"
                                        AutomationProperties.Name="Add tag"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        KeyDown="OnTagInputKeyDown"
                                        PlaceholderText="Add tag"
                                        TextChanged="OnTagInputTextChanged" />
                                </StackPanel>
                            </Border>
                            <Border
                                MaxHeight="116"
                                Background="{StaticResource PromptNestPaneElevatedBrush}"
                                BorderBrush="{StaticResource PromptNestBorderMutedBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource PromptNestControlRadius}"
                                Visibility="{Binding Library.IsTagSuggestionOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ItemsControl ItemsSource="{Binding Library.FilteredTagSuggestions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button
                                                MinHeight="28"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                Click="OnTagSuggestionClick"
                                                Content="{Binding}"
                                                Foreground="{StaticResource PromptNestTextPrimaryBrush}"
                                                Tag="{Binding}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="34" />
                        <RowDefinition Height="124" />
                    </Grid.RowDefinitions>
                    <Grid
                        Background="{StaticResource PromptNestEditorBrush}"
                        BorderBrush="{StaticResource PromptNestBorderMutedBrush}"
                        BorderThickness="1"
                        ColumnSpacing="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Background="{StaticResource PromptNestPaneBrush}"
                            BorderBrush="{StaticResource PromptNestBorderMutedBrush}"
                            BorderThickness="0,0,1,0">
                            <TextBlock
                                x:Name="EditorLineNumbers"
                                Padding="0,12,8,0"
                                AutomationProperties.AccessibilityView="Raw"
                                FontFamily="{StaticResource PromptNestFontFamilyEditor}"
                                FontSize="{StaticResource PromptNestFontSizeEditor}"
                                Foreground="{StaticResource PromptNestTextTertiaryBrush}"
                                IsHitTestVisible="False"
                                Text="1"
                                TextAlignment="Right" />
                        </Border>
                        <TextBox
                            x:Name="PromptBodyEditor"
                            Grid.Column="1"
                            AcceptsReturn="True"
                            AutomationProperties.AutomationId="PromptNest.PromptBodyEditor"
                            AutomationProperties.Name="Prompt body"
                            AutomationProperties.HelpText="Edit the prompt body. Press Control plus E to focus."
                            BorderThickness="0"
                            PlaceholderText="Write your prompt..."
                            SelectionChanged="OnPromptBodySelectionChanged"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            Text="{Binding Library.SelectedPrompt.Body, Mode=OneWay}"
                            TextChanged="OnPromptBodyTextChanged"
                            TextWrapping="Wrap"
                            Style="{StaticResource PromptNestEditorTextBoxStyle}" />
                    </Grid>

                    <Grid
                        Grid.Row="1"
                        Padding="10,0"
                        Background="{StaticResource PromptNestEditorBrush}"
                        BorderBrush="{StaticResource PromptNestBorderMutedBrush}"
                        BorderThickness="1,0,1,1">
                        <StackPanel
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="10">
                            <TextBlock
                                x:Name="EditorPositionText"
                                Style="{StaticResource PromptNestStatusTextStyle}"
                                Text="Ln 1, Col 1" />
                            <TextBlock
                                x:Name="EditorCharacterCountText"
                                Style="{StaticResource PromptNestStatusTextStyle}"
                                Text="0 characters" />
                            <TextBlock
                                Style="{StaticResource PromptNestStatusTextStyle}"
                                Text="Markdown" />
                        </StackPanel>
                        <StackPanel
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="8">
                            <Button
                                Width="{StaticResource PromptNestSmallIconButtonSize}"
                                Height="{StaticResource PromptNestSmallIconButtonSize}"
                                AutomationProperties.Name="Editor text size"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Content="Aa"
                                CornerRadius="{StaticResource PromptNestControlRadius}"
                                FontSize="{StaticResource PromptNestFontSizeBodySmall}"
                                Foreground="{StaticResource PromptNestTextSecondaryBrush}"
                                Padding="0"
                                ToolTipService.ToolTip="Editor text size" />
                            <Button
                                Width="{StaticResource PromptNestSmallIconButtonSize}"
                                Height="{StaticResource PromptNestSmallIconButtonSize}"
                                AutomationProperties.Name="Expand prompt editor"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                CornerRadius="{StaticResource PromptNestControlRadius}"
                                Padding="0"
                                ToolTipService.ToolTip="Expand prompt editor">
                                <FontIcon
                                    FontSize="{StaticResource PromptNestIconGlyphMedium}"
                                    Foreground="{StaticResource PromptNestIconDefaultBrush}"
                                    Glyph="&#xE740;" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Border
                        Grid.Row="2"
                        Margin="0,10,0,0"
                        Background="{StaticResource PromptNestEditorBrush}"
                        BorderBrush="{StaticResource PromptNestBorderMutedBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource PromptNestControlRadius}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid
                                Padding="10,0"
                                Background="{StaticResource PromptNestPaneBrush}"
                                ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.1*" />
                                    <ColumnDefinition Width="1.5*" />
                                    <ColumnDefinition Width="0.8*" />
                                    <ColumnDefinition Width="1.3*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center" Style="{StaticResource PromptNestStatusTextStyle}" Text="Name" />
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Style="{StaticResource PromptNestStatusTextStyle}" Text="Default" />
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Style="{StaticResource PromptNestStatusTextStyle}" Text="Type" />
                                <TextBlock Grid.Column="3" VerticalAlignment="Center" Style="{StaticResource PromptNestStatusTextStyle}" Text="Preview" />
                            </Grid>
                            <ListView
                                Grid.Row="1"
                                Background="Transparent"
                                BorderThickness="0"
                                ItemsSource="{Binding Library.SelectedPrompt.Variables}"
                                SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid
                                            MinHeight="40"
                                            Padding="10,4"
                                            ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.1*" />
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="0.8*" />
                                                <ColumnDefinition Width="1.3*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource PromptNestTextPrimaryBrush}"
                                                Text="{Binding Name}" />
                                            <TextBox
                                                Grid.Column="1"
                                                Height="30"
                                                Text="{Binding DefaultValue, Mode=OneWay}" />
                                            <ComboBox
                                                Grid.Column="2"
                                                Height="30"
                                                SelectedIndex="0">
                                                <ComboBoxItem Content="text" />
                                            </ComboBox>
                                            <TextBox
                                                Grid.Column="3"
                                                Height="30"
                                                Text="{Binding PreviewValue, Mode=OneWay}" />
                                            <Button
                                                Grid.Column="4"
                                                Width="{StaticResource PromptNestSmallIconButtonSize}"
                                                Height="{StaticResource PromptNestSmallIconButtonSize}"
                                                AutomationProperties.Name="Delete variable"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                CornerRadius="{StaticResource PromptNestControlRadius}"
                                                IsEnabled="{Binding CanDelete}"
                                                Padding="0"
                                                ToolTipService.ToolTip="Delete variable">
                                                <FontIcon
                                                    FontSize="{StaticResource PromptNestIconGlyphSmall}"
                                                    Foreground="{StaticResource PromptNestIconDefaultBrush}"
                                                    Glyph="&#xE74D;" />
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>

                <Grid
                    Grid.Row="3"
                    BorderBrush="{StaticResource PromptNestBorderMutedBrush}"
                    BorderThickness="0,1,0,0">
                    <TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Foreground="{Binding Library.Validation.State, Converter={StaticResource ValidationStateToBrushConverter}}"
                        Style="{StaticResource PromptNestStatusTextStyle}"
                        Text="{Binding Library.Validation.SummaryText}" />
                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="10">
                        <Button
                            MinWidth="86"
                            Height="34"
                            AccessKey="C"
                            AutomationProperties.AutomationId="PromptNest.CopyButton"
                            AutomationProperties.Name="Copy prompt to clipboard"
                            Background="{StaticResource PromptNestPaneElevatedBrush}"
                            BorderBrush="Transparent"
                            Click="OnCopySelectedPromptClick"
                            Content="Copy"
                            CornerRadius="{StaticResource PromptNestControlRadius}"
                            Foreground="{StaticResource PromptNestTextPrimaryBrush}"
                            ToolTipService.ToolTip="Copy prompt to clipboard" />
                        <Button
                            MinWidth="86"
                            Height="34"
                            AccessKey="S"
                            AutomationProperties.AutomationId="PromptNest.SaveButton"
                            AutomationProperties.Name="Save prompt"
                            Background="{StaticResource PromptNestAccentBrush}"
                            BorderBrush="Transparent"
                            Click="OnSaveEditorClick"
                            Content="Save"
                            CornerRadius="{StaticResource PromptNestControlRadius}"
                            Foreground="{StaticResource PromptNestIconSelectedBrush}"
                            IsEnabled="{Binding Library.CanSave}"
                            ToolTipService.ToolTip="Save changes (Ctrl+S)" />
                        <Button
                            MinWidth="86"
                            Height="34"
                            AutomationProperties.AutomationId="PromptNest.CancelButton"
                            AutomationProperties.Name="Cancel changes"
                            Background="{StaticResource PromptNestPaneElevatedBrush}"
                            BorderBrush="Transparent"
                            Click="OnCancelEditorClick"
                            Content="Cancel"
                            CornerRadius="{StaticResource PromptNestControlRadius}"
                            Foreground="{StaticResource PromptNestTextPrimaryBrush}"
                            IsEnabled="{Binding Library.CanCancel}"
                            ToolTipService.ToolTip="Discard unsaved changes" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
