<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="PromptNest.App.Views.PaletteWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PromptNest Palette">
    <Grid
        Width="600"
        Height="420"
        Padding="16"
        AutomationProperties.Name="PromptNest quick palette"
        Background="{StaticResource PromptNestEditorBrush}"
        RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="42" />
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <TextBox
            x:Name="PaletteSearchBox"
            AutomationProperties.AutomationId="PromptNest.PaletteSearchBox"
            AutomationProperties.Name="Search prompts"
            AutomationProperties.HelpText="Type to search. Down arrow next, up arrow previous, Enter to copy, Escape to close."
            PlaceholderText="Search prompts"
            Style="{StaticResource PromptNestSearchBoxStyle}"
            TextChanged="OnSearchTextChanged" />

        <ListView
            Grid.Row="1"
            AutomationProperties.AutomationId="PromptNest.PaletteResultList"
            AutomationProperties.Name="Search results"
            Background="Transparent"
            BorderThickness="0"
            ItemClick="OnResultClick"
            IsItemClickEnabled="True"
            ItemsSource="{Binding Results}"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border
                        MinHeight="58"
                        Padding="10"
                        BorderBrush="{StaticResource PromptNestBorderMutedBrush}"
                        BorderThickness="0,0,0,1">
                        <StackPanel Spacing="4">
                            <TextBlock
                                FontWeight="SemiBold"
                                Foreground="{StaticResource PromptNestTextPrimaryBrush}"
                                Text="{Binding Title}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                Foreground="{StaticResource PromptNestTextSecondaryBrush}"
                                MaxLines="1"
                                Text="{Binding Preview}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid Grid.Row="2">
            <TextBlock
                VerticalAlignment="Center"
                AutomationProperties.LiveSetting="Polite"
                Style="{StaticResource PromptNestStatusTextStyle}"
                Text="{Binding StatusText}" />
            <TextBlock
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                AutomationProperties.AccessibilityView="Raw"
                Style="{StaticResource PromptNestStatusTextStyle}"
                Text="Enter: copy   Alt+Enter: edit   Esc: close" />
        </Grid>
    </Grid>
</Window>
