<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <FontFamily x:Key="PromptNestFontFamilyUi">Segoe UI Variable Text, Segoe UI</FontFamily>
    <FontFamily x:Key="PromptNestFontFamilyDisplay">Segoe UI Variable Display, Segoe UI</FontFamily>
    <FontFamily x:Key="PromptNestFontFamilyEditor">Cascadia Code, Consolas</FontFamily>

    <x:Double x:Key="PromptNestFontSizeCaption">11</x:Double>
    <x:Double x:Key="PromptNestFontSizeBodySmall">12</x:Double>
    <x:Double x:Key="PromptNestFontSizeBody">13</x:Double>
    <x:Double x:Key="PromptNestFontSizeBodyLarge">14</x:Double>
    <x:Double x:Key="PromptNestFontSizeTitle">16</x:Double>
    <x:Double x:Key="PromptNestFontSizeEditor">13</x:Double>

    <x:Double x:Key="PromptNestLineHeightTight">16</x:Double>
    <x:Double x:Key="PromptNestLineHeightBody">20</x:Double>
    <x:Double x:Key="PromptNestLineHeightEditor">22</x:Double>
</ResourceDictionary>
