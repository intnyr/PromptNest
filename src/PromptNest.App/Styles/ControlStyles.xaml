<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="PromptNestToolbarButtonStyle" TargetType="Button">
        <Setter Property="MinWidth" Value="32" />
        <Setter Property="Height" Value="{StaticResource PromptNestIconButtonSize}" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="CornerRadius" Value="{StaticResource PromptNestControlRadius}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource PromptNestTextPrimaryBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource PromptNestFontFamilyUi}" />
        <Setter Property="FontSize" Value="{StaticResource PromptNestFontSizeBody}" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
        <Setter Property="FocusVisualPrimaryBrush" Value="{StaticResource PromptNestFocusStrokeBrush}" />
        <Setter Property="FocusVisualSecondaryBrush" Value="{StaticResource PromptNestFocusStrokeOuterBrush}" />
        <Setter Property="FocusVisualPrimaryThickness" Value="{StaticResource PromptNestFocusStrokeThickness}" />
    </Style>

    <Style x:Key="PromptNestIconButtonStyle" TargetType="Button" BasedOn="{StaticResource PromptNestToolbarButtonStyle}">
        <Setter Property="MinWidth" Value="{StaticResource PromptNestIconButtonSize}" />
        <Setter Property="Width" Value="{StaticResource PromptNestIconButtonSize}" />
        <Setter Property="Height" Value="{StaticResource PromptNestIconButtonSize}" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="PromptNestSectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PromptNestFontFamilyUi}" />
        <Setter Property="FontSize" Value="{StaticResource PromptNestFontSizeCaption}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="{StaticResource PromptNestSectionHeaderSpacing}" />
        <Setter Property="Foreground" Value="{StaticResource PromptNestTextTertiaryBrush}" />
        <Setter Property="AutomationProperties.HeadingLevel" Value="Level2" />
    </Style>

    <Style x:Key="PromptNestFieldLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PromptNestFontFamilyUi}" />
        <Setter Property="FontSize" Value="{StaticResource PromptNestFontSizeBodySmall}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource PromptNestTextPrimaryBrush}" />
    </Style>

    <Style x:Key="PromptNestPrimaryToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource PromptNestToolbarButtonStyle}">
        <Setter Property="Background" Value="{StaticResource PromptNestAccentBrush}" />
        <Setter Property="Foreground" Value="{StaticResource PromptNestIconSelectedBrush}" />
    </Style>

    <Style x:Key="PromptNestSearchBoxStyle" TargetType="TextBox">
        <Setter Property="Height" Value="38" />
        <Setter Property="Padding" Value="12,0,12,0" />
        <Setter Property="CornerRadius" Value="{StaticResource PromptNestControlRadius}" />
        <Setter Property="Background" Value="{StaticResource PromptNestPaneBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PromptNestBorderStrongBrush}" />
        <Setter Property="Foreground" Value="{StaticResource PromptNestTextPrimaryBrush}" />
        <Setter Property="PlaceholderForeground" Value="{StaticResource PromptNestPlaceholderBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource PromptNestFontFamilyUi}" />
        <Setter Property="FontSize" Value="{StaticResource PromptNestFontSizeBodyLarge}" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
    </Style>

    <Style x:Key="PromptNestPromptListRowStyle" TargetType="ListViewItem">
        <Setter Property="Height" Value="{StaticResource PromptNestListRowHeight}" />
        <Setter Property="Padding" Value="{StaticResource PromptNestListRowPadding}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{StaticResource PromptNestBorderMutedBrush}" />
        <Setter Property="Foreground" Value="{StaticResource PromptNestTextPrimaryBrush}" />
    </Style>

    <Style x:Key="PromptNestFolderRowStyle" TargetType="ListViewItem">
        <Setter Property="Height" Value="{StaticResource PromptNestFolderRowHeight}" />
        <Setter Property="Padding" Value="{StaticResource PromptNestFolderRowPadding}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Foreground" Value="{StaticResource PromptNestTextSecondaryBrush}" />
    </Style>

    <Style x:Key="PromptNestTagChipStyle" TargetType="Border">
        <Setter Property="MinHeight" Value="{StaticResource PromptNestTagChipHeight}" />
        <Setter Property="Padding" Value="{StaticResource PromptNestTagChipPadding}" />
        <Setter Property="CornerRadius" Value="{StaticResource PromptNestTagChipRadius}" />
        <Setter Property="Background" Value="{StaticResource PromptNestAccentSubtleBrush}" />
    </Style>

    <Style x:Key="PromptNestCommandTabStyle" TargetType="Button">
        <Setter Property="Height" Value="{StaticResource PromptNestCommandTabHeight}" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource PromptNestTextSecondaryBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource PromptNestFontFamilyUi}" />
        <Setter Property="FontSize" Value="{StaticResource PromptNestFontSizeBody}" />
    </Style>

    <Style x:Key="PromptNestEditorTextBoxStyle" TargetType="TextBox">
        <Setter Property="Padding" Value="{StaticResource PromptNestEditorPadding}" />
        <Setter Property="Background" Value="{StaticResource PromptNestEditorBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PromptNestBorderMutedBrush}" />
        <Setter Property="Foreground" Value="{StaticResource PromptNestTextPrimaryBrush}" />
        <Setter Property="PlaceholderForeground" Value="{StaticResource PromptNestPlaceholderBrush}" />
        <Setter Property="SelectionHighlightColor" Value="{StaticResource PromptNestAccentBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource PromptNestFontFamilyEditor}" />
        <Setter Property="FontSize" Value="{StaticResource PromptNestFontSizeEditor}" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
    </Style>

    <Style x:Key="PromptNestStatusTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource PromptNestTextTertiaryBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource PromptNestFontFamilyUi}" />
        <Setter Property="FontSize" Value="{StaticResource PromptNestFontSizeBodySmall}" />
    </Style>
</ResourceDictionary>
